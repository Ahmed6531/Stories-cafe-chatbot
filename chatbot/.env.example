APP_NAME=Stories Cafe Chatbot Service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

EXPRESS_API_BASE_URL=http://localhost:5000

OPENAI_PROVIDER=azure
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Cloud STT credentials for Speech-to-Text (STT) provider.
GOOGLE_CREDENTIALS_JSON=

# ── Text-to-Speech ────────────────────────────────────────────────
# Set TTS_ENABLED=true to activate Google Cloud TTS on bot replies.
# Uses the same GOOGLE_CREDENTIALS_JSON service account as STT.
# Voice options: en-US-Journey-F (default), en-US-Journey-D (male),
#   en-US-Neural2-F, en-US-Neural2-C
TTS_ENABLED=true
TTS_VOICE=en-US-Journey-F

# Voice personality controls how expressive the chatbot sounds.
# Options:
# - default: balanced and natural
# - fun_demo: slightly more upbeat, brighter, and demo-friendly
TTS_PERSONALITY=fun_demo